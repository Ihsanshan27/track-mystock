{
  "name": "jurnal-saham",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts",
    "build": "vite build --config apps/web/vite.config.ts",
    "api:dev": "npm --prefix apps/api run dev",
    "api:build": "npm --prefix apps/api run build",
    "api:start": "npm --prefix apps/api run start",
    "api:prisma:generate": "npm --prefix apps/api run prisma:generate",
    "api:prisma:migrate": "node --env-file=.env ./apps/api/node_modules/prisma/build/index.js migrate dev --schema=./apps/api/prisma/schema.prisma",
    "api:prisma:deploy": "node --env-file=.env ./apps/api/node_modules/prisma/build/index.js migrate deploy --schema=./apps/api/prisma/schema.prisma",
    "api:seed": "node --env-file=.env --import tsx ./apps/api/src/scripts/seed-dev.ts",
    "lint": "eslint .",
    "test": ".\\node_modules\\.bin\\vitest.cmd run --config vitest.config.mjs --configLoader runner",
    "test:watch": ".\\node_modules\\.bin\\vitest.cmd --config vitest.config.mjs --configLoader runner",
    "preview": "vite preview --config apps/web/vite.config.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.11.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "technicalindicators": "^3.1.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.9"
  }
}
