{
  "name": "jurnal-saham-api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-watch.ps1",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -w -p tsconfig.build.json --preserveWatchOutput",
    "start": "node dist/main.js",
    "start:watch": "node --watch dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "migrate:journal-data": "tsx src/scripts/migrate-journal-data.ts",
    "lock:journal-data": "tsx src/scripts/lock-journal-data-readonly.ts",
    "verify:journal-data": "tsx src/scripts/verify-journal-data-migration.ts",
    "seed:dev": "tsx src/scripts/seed-dev.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
